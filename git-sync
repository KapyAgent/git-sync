#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "watchdog",
# ]
# ///

import os
import sys
import subprocess
import shutil
import signal
import time
import argparse
from pathlib import Path
from watchdog.observers import Observer
from watchdog.events import FileSystemEventHandler

def run_git(args, cwd):
    return subprocess.run(["git"] + args, cwd=cwd, capture_output=True, text=True)

def is_ignored(path, root):
    res = run_git(["check-ignore", "-q", str(path)], cwd=root)
    return res.returncode == 0

def cleanup_dest(dest):
    print(f"Cleaning up {dest}...")
    run_git(["reset", "--hard", "HEAD"], cwd=dest)
    run_git(["clean", "-fd"], cwd=dest)

def remove_path(src_path, src_root, dest_root):
    rel_path = os.path.relpath(src_path, src_root)
    dest_path = os.path.join(dest_root, rel_path)
    if os.path.exists(dest_path):
        if os.path.isdir(dest_path):
            shutil.rmtree(dest_path)
        else:
            os.remove(dest_path)

def main():
    parser = argparse.ArgumentParser(description="Sync git worktree changes from src to dest.")
    parser.add_argument("src", help="Source directory (feat branch)")
    parser.add_argument("dest", help="Destination directory (main branch)")
    parser.add_argument("cmd", nargs=argparse.REMAINDER, help="Optional command and arguments to run while syncing")
    args = parser.parse_args()

    src = os.path.abspath(args.src)
    dest = os.path.abspath(args.dest)

    if not os.path.isdir(src) or not os.path.isdir(dest):
        print("Error: src and dest must be directories.")
        sys.exit(1)

    # Ensure src and dest belong to the same git repository
    src_common_raw = run_git(["rev-parse", "--git-common-dir"], src).stdout.strip()
    dest_common_raw = run_git(["rev-parse", "--git-common-dir"], dest).stdout.strip()

    if not src_common_raw or not dest_common_raw:
        print("Error: Could not find git common directory for src or dest.")
        sys.exit(1)

    # Convert to absolute paths to avoid relative path comparison issues
    src_common = os.path.abspath(os.path.join(src, src_common_raw))
    dest_common = os.path.abspath(os.path.join(dest, dest_common_raw))

    if src_common != dest_common:
        print(f"Error: src and dest must belong to the same git repository.\nSrc common: {src_common}\nDest common: {dest_common}")
        sys.exit(1)

    cleanup_dest(dest)

    # State management
    wrapper_proc = None
    exit_status = 0

    def signal_handler(sig, frame):
        nonlocal exit_status
        if sig == signal.SIGUSR1:
            print("\nFATAL ERROR: sync conflict detected. Terminating...")
            exit_status = 1
        else:
            print("\nStopping sync...")
        
        observer.stop()
        if wrapper_proc:
            try:
                # Terminate the entire process group
                pgid = os.getpgid(wrapper_proc.pid)
                os.killpg(pgid, signal.SIGTERM)
                time.sleep(0.5)
                if wrapper_proc.poll() is None:
                    os.killpg(pgid, signal.SIGKILL)
            except (ProcessLookupError, PermissionError, OSError):
                pass
        
        cleanup_dest(dest)
        sys.exit(exit_status)

    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    signal.signal(signal.SIGHUP, signal_handler)
    signal.signal(signal.SIGUSR1, signal_handler)

    def safe_sync(path, s_root, d_root):
        rel_path = os.path.relpath(path, s_root)
        if is_ignored(rel_path, s_root):
            return
        if is_ignored(rel_path, d_root):
            print(f"\nFATAL: {rel_path} is ignored in destination {d_root}. Aborting.")
            os.kill(os.getpid(), signal.SIGUSR1)
            return
        
        dest_path = os.path.join(d_root, rel_path)
        if os.path.isdir(path):
            os.makedirs(dest_path, exist_ok=True)
        else:
            os.makedirs(os.path.dirname(dest_path), exist_ok=True)
            shutil.copy2(path, dest_path)

    # Initial Sync Logic: Batch files to sync
    print(f"Performing initial sync from {src} to {dest}...")
    
    # 1. Get all files to sync from src (cached + others - ignored)
    ls_files_res = run_git(["ls-files", "--cached", "--others", "--exclude-standard", "-z"], src)
    if ls_files_res.returncode != 0:
        print("Error: Failed to list files in source.")
        sys.exit(1)
        
    files_to_sync = [f for f in ls_files_res.stdout.split('\0') if f]
    
    # 2. Check if any of these files are ignored in dest (batch check)
    if files_to_sync:
        check_ignore_res = subprocess.run(
            ["git", "check-ignore", "--stdin", "-z"],
            cwd=dest, input='\0'.join(files_to_sync), capture_output=True, text=True
        )
        ignored_in_dest = [f for f in check_ignore_res.stdout.split('\0') if f]
        
        if ignored_in_dest:
            print(f"\nFATAL: The following files are ignored in destination {dest}. Aborting.")
            for f in ignored_in_dest:
                print(f"  {f}")
            cleanup_dest(dest)
            sys.exit(1)

        # 3. Perform Sync (Copy files)
        for rel_path in files_to_sync:
            src_path = os.path.join(src, rel_path)
            dest_path = os.path.join(dest, rel_path)
            if os.path.isdir(src_path):
                os.makedirs(dest_path, exist_ok=True)
            else:
                os.makedirs(os.path.dirname(dest_path), exist_ok=True)
                shutil.copy2(src_path, dest_path)

    print("Initial sync completed.")

    class SyncHandler(FileSystemEventHandler):
        def on_modified(self, event):
            if not event.is_directory:
                safe_sync(event.src_path, src, dest)
        def on_created(self, event):
            safe_sync(event.src_path, src, dest)
        def on_deleted(self, event):
            remove_path(event.src_path, src, dest)
        def on_moved(self, event):
            remove_path(event.src_path, src, dest)
            safe_sync(event.dest_path, src, dest)

    observer = Observer()
    observer.schedule(SyncHandler(), src, recursive=True)
    observer.start()

    cmd_list = args.cmd
    if cmd_list:
        cmd_string = " ".join(cmd_list)
        print(f"Running command: {cmd_string}")
        # Use start_new_session to ensure we can kill the whole group
        wrapper_proc = subprocess.Popen(cmd_string, shell=True, start_new_session=True)
        try:
            while wrapper_proc.poll() is None:
                time.sleep(0.5)
            if exit_status == 0:
                exit_status = wrapper_proc.returncode
            print(f"Command exited with code {wrapper_proc.returncode}")
        except KeyboardInterrupt:
            pass
        finally:
            signal_handler(signal.SIGINT, None)
    else:
        print("Syncing... Press Ctrl+C to stop.")
        try:
            while True:
                time.sleep(1)
        except KeyboardInterrupt:
            signal_handler(signal.SIGINT, None)

if __name__ == "__main__":
    main()
